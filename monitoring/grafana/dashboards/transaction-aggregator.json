{
  "title": "Transaction Aggregator",
  "uid": "transaction-aggregator",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Transactions Synced (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(transactions_synced_total{application=\"transaction-aggregator\"}[1m]) * 60",
          "legendFormat": "synced/min",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Sync Errors (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(sync_errors_total{application=\"transaction-aggregator\"}[1m]) * 60",
          "legendFormat": "{{source}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "HTTP Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"transaction-aggregator\"}[1m]) * 60",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    },
    {
      "id": 4,
      "title": "HTTP P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"transaction-aggregator\"}[1m])) * 1000",
          "legendFormat": "p99 {{uri}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 5,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"transaction-aggregator\", area=\"heap\"}",
          "legendFormat": "{{id}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 6,
      "title": "JVM GC Pause Rate (ms/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"transaction-aggregator\"}[1m]) * 1000",
          "legendFormat": "{{action}} {{cause}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "R2DBC Connection Pool — Acquired",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "r2dbc_pool_acquired{application=\"transaction-aggregator\"}",
          "legendFormat": "acquired",
          "datasource": "Prometheus"
        },
        {
          "expr": "r2dbc_pool_pending{application=\"transaction-aggregator\"}",
          "legendFormat": "pending",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Active Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"transaction-aggregator\"}",
          "legendFormat": "live",
          "datasource": "Prometheus"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"transaction-aggregator\"}",
          "legendFormat": "daemon",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
